{
    "$schema": "https://json.schemastore.org/package",
    "name": "@kayahr/scope",
    "version": "0.1.0",
    "type": "module",
    "description": "Ownership scopes, cleanup callbacks, and typed scope-local values for TypeScript",
    "keywords": [
        "scope",
        "ownership",
        "dispose",
        "disposable",
        "lifecycle",
        "cleanup",
        "context",
        "slot",
        "typescript",
        "browser",
        "nodejs"
    ],
    "license": "MIT",
    "author": "Klaus Reimer <k@ailis.de>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kayahr/scope.git"
    },
    "homepage": "https://github.com/kayahr/scope",
    "bugs": "https://github.com/kayahr/scope/issues",
    "funding": "https://github.com/kayahr/scope?sponsor=1",
    "publishConfig": {
        "access": "public"
    },
    "sideEffects": false,
    "files": [
        "lib/main/",
        "src/main/"
    ],
    "exports": "./lib/main/index.js",
    "scripts": {
        "clean": "rm -rf lib",
        "build": "run build:*",
        "build:compile": "tsc",
        "test": "run test:*",
        "test:unit": "ntest",
        "test:spell": "cspell --no-progress --no-summary",
        "test:lint": "oxlint --type-aware --deny-warnings",
        "test:apidoc": "typedoc --emit none",
        "apidoc": "typedoc",
        "prepare": "run clean build"
    },
    "devDependencies": {
        "@kayahr/assert": "1.4.1",
        "@kayahr/cspell": "9.7.0-bundle.1",
        "@kayahr/npm-utils": "1.1.2",
        "@kayahr/ntest": "1.3.0",
        "@kayahr/oxlint-config": "1.32.0",
        "@kayahr/typedoc": "0.28.18-bundle.1",
        "@types/node": "25.6.0",
        "typescript": "6.0.2"
    }
}
